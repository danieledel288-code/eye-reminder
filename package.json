{
  "name": "eye-reminder",
  "version": "1.4.0",
  "productName": "Eye Reminder",
  "description": "20-20-20 eye break reminder",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.daniel.eyereminder",
    "productName": "Eye Reminder",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Eye Reminder"
    },
    "files": [
      "main.js",
      "preload.js",
      "ui.html",
      "overlay.html",
      "icon.ico",
      "icon.png"
    ]
  }
}
